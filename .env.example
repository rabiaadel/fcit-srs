# =============================================================================
# FCIT SRS - Environment Variables
# Copy this to .env and update secrets before production use
# =============================================================================

# -- Database -----------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=student_registration_system

# -- Backend ------------------------------------------------------------------
NODE_ENV=development
BACKEND_PORT=3000

# CHANGE THESE IN PRODUCTION -- generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

API_RATE_LIMIT=200
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3002,http://localhost:8080

# -- Frontend -----------------------------------------------------------------
FRONTEND_PORT=3002
REACT_APP_API_URL=/api/v1
REACT_APP_ENV=development

# -- Monitoring ---------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_strong_password_here
