# =============================================================================
# Dockerfile.db - PostgreSQL with initialization
# =============================================================================
FROM postgres:16-alpine
LABEL description="FCIT SRS - PostgreSQL Database"
RUN apk add --no-cache postgresql-client
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD pg_isready -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-student_registration_system} || exit 1
EXPOSE 5432
VOLUME ["/var/lib/postgresql/data"]
